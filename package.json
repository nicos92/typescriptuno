{
  "name": "todo-api-coupled",
  "version": "1.0.0",
  "description": "Coupled N-Tier Todo API",
  "main": "src/server.ts",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node src/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "reflect-metadata": "^0.1.13",
    "sqlite3": "^5.1.6",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.5.0",
    "only-allow": "^1.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  }
}
